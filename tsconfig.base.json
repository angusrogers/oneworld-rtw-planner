{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@rtw/shared": ["./packages/shared/src/index.ts"],
      "@rtw/rules-engine": ["./packages/rules-engine/src/index.ts"]
    },
    "baseUrl": "."
  }
}
